# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=automation_yt

# Puertos expuestos en el host (cambia si chocan con otro proyecto local)
BACKEND_PORT=8000
FRONTEND_PORT=3000

# YouTube Data API v3 (research de competencia). Crear en Google Cloud Console.
YOUTUBE_API_KEY=

# OAuth por canal (publish automático). Misma Google Cloud Console,
# crear credenciales OAuth 2.0 tipo "Aplicación web".
# URI de redirección autorizada: http://localhost:8000/oauth/callback
# (en producción: https://tu-dominio.com/oauth/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL pública del backend (usada en el callback OAuth)
BASE_URL=http://localhost:8000

ENVIRONMENT=production

# HuggingFace token (gratuito) para visual_style "ai" — generación de video con IA.
# Crear en https://huggingface.co/settings/tokens (Read token es suficiente)
HF_TOKEN=

# Login de la plataforma (password única compartida, protege el frontend)
APP_LOGIN_PASSWORD=
# Token de sesión aleatorio, genera el tuyo con: openssl rand -hex 32
APP_SESSION_TOKEN=
